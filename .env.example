# ─── LLM API Keys ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the keys for the providers you want to use.
# .env is gitignored and stays local only.

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Local LLM (Ollama) — runs on localhost, no key needed
# Set the base URL if Ollama runs on a non-default host/port
OLLAMA_BASE_URL=http://127.0.0.1:11434
